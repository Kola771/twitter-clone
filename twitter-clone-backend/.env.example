# Base de données PostgreSQL
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/twitter_clone"

# JWT — génère des secrets longs et aléatoires en prod (ex: openssl rand -base64 64)
JWT_SECRET="change_me_in_production_jwt_secret_very_long"
JWT_REFRESH_SECRET="change_me_in_production_refresh_secret_very_long"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Cloudinary (optionnel — pour l'upload d'images)
# Créer un compte sur https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Port du serveur (défaut : 3001)
PORT=3001
